---
import PageHeader from '../components/PageHeader.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectFilters from '../components/ProjectFilters.astro';
import type { Locale } from '../config/site';
import { getUi } from '../i18n/ui';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublicProjects } from '../lib/content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getUi(locale);
const projects = await getPublicProjects(locale);
---

<BaseLayout locale={locale} title={t.projects.title} description={t.projects.description} canonicalPath="/projects/">
  <PageHeader eyebrow={t.projects.eyebrow} title={t.projects.heading} description={t.projects.intro} />
  <section
    class="mx-auto grid w-full max-w-7xl gap-8 px-5 pb-20 sm:px-6 lg:grid-cols-[21rem_1fr] lg:px-8"
    data-project-filter-root
    data-filter-label={t.projects.showingLabel}
    data-filter-locale={locale}
  >
    <div class="lg:sticky lg:top-24 lg:self-start"><ProjectFilters projects={projects} locale={locale} /></div>
    <div>
      <div class="grid gap-5 xl:grid-cols-2">
        {projects.map((project) => <ProjectCard project={project} locale={locale} />)}
      </div>
      <div class="surface-card mt-6 hidden rounded-lg p-6 text-sm text-site-muted" data-filter-empty>{t.projects.empty}</div>
    </div>
  </section>
</BaseLayout>
