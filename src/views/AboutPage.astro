---
import PageHeader from '../components/PageHeader.astro';
import type { Locale } from '../config/site';
import { getUi } from '../i18n/ui';
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getUi(locale);
---

<BaseLayout locale={locale} title={t.about.title} description={t.about.description} canonicalPath="/about/">
  <PageHeader eyebrow={t.about.eyebrow} title={t.about.heading} description={t.about.intro} />
  <section class="mx-auto grid w-full max-w-7xl gap-5 px-5 pb-20 sm:px-6 md:grid-cols-2 lg:grid-cols-3 lg:px-8">
    {t.about.principles.map(([title, text]) => (
      <article class="surface-card rounded-lg p-6">
        <h2 class="text-xl font-semibold tracking-[-0.025em]">{title}</h2>
        <p class="mt-4 text-sm leading-7 text-site-muted">{text}</p>
      </article>
    ))}
  </section>
</BaseLayout>
