---
import PageHeader from '../components/PageHeader.astro';
import SearchClient from '../components/SearchClient.astro';
import type { Locale } from '../config/site';
import { getUi } from '../i18n/ui';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublicProjects, getPublishedNotes } from '../lib/content';
import { getPulseEntries } from '../lib/pulse';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getUi(locale);
const projects = await getPublicProjects(locale);
const notes = await getPublishedNotes(locale);
const pulses = getPulseEntries();
---

<BaseLayout locale={locale} title={t.search.title} description={t.search.description} canonicalPath="/search/">
  <PageHeader eyebrow={t.search.eyebrow} title={t.search.heading} description={t.search.intro} />
  <section class="mx-auto w-full max-w-4xl px-5 pb-20 sm:px-6 lg:px-8"><SearchClient projects={projects} notes={notes} pulses={pulses} locale={locale} /></section>
</BaseLayout>
