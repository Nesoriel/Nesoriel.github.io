---
import type { NoteEntry } from '../lib/content';
import { type Locale } from '../config/site';
import { getUi } from '../i18n/ui';
import { uniqueSorted } from '../lib/content';

interface Props {
  notes: NoteEntry[];
  locale: Locale;
}

const { notes, locale } = Astro.props;
const t = getUi(locale);
const normalize = (value: string) => value.trim().toLowerCase();
const categories = uniqueSorted(notes.map((note) => note.data.category));
const tags = uniqueSorted(notes.flatMap((note) => note.data.tags));

const buttonClass = 'focus-ring rounded-md border border-site-border px-3 py-2 text-sm transition hover:border-site-border-strong hover:text-site';
---

<section class="surface-card rounded-lg p-6" aria-labelledby="note-filters-title">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h2 id="note-filters-title" class="text-lg font-semibold tracking-[-0.03em] text-site">{t.notes.filtersTitle}</h2>
      <p class="mt-2 text-sm text-site-muted">{t.notes.filtersDescription}</p>
    </div>
    <p class="text-sm text-site-subtle" aria-live="polite" data-filter-results>{locale === 'zh-cn' ? `${notes.length} ${t.notes.showingLabel}` : `Showing ${notes.length} ${t.notes.showingLabel}`}</p>
  </div>

  <div class="mt-6 space-y-5">
    <div>
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-site-subtle">{t.notes.category}</p>
      <div class="mt-3 flex flex-wrap gap-2" role="toolbar" aria-label={t.notes.categoryAria} data-filter-group="category">
        <button type="button" class={buttonClass} data-filter-value="all" aria-pressed="true">{t.common.all}</button>
        {categories.map((category) => <button type="button" class={buttonClass} data-filter-value={normalize(category)} aria-pressed="false">{category}</button>)}
      </div>
    </div>

    <div>
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-site-subtle">{t.notes.tags}</p>
      <div class="mt-3 flex flex-wrap gap-2" role="toolbar" aria-label={t.notes.tagsAria} data-filter-group="tags">
        <button type="button" class={buttonClass} data-filter-value="all" aria-pressed="true">{t.common.all}</button>
        {tags.map((tag) => <button type="button" class={buttonClass} data-filter-value={normalize(tag)} aria-pressed="false">{tag}</button>)}
      </div>
    </div>
  </div>
</section>

<script>
  import { setupCollectionFilters } from '../lib/client/collection-filters';
  setupCollectionFilters('[data-note-filter-root]');
</script>
