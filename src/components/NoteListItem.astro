---
import TagPill from './TagPill.astro';
import { localizedPath, type Locale } from '../config/site';
import { formatDate, readingTime, type NoteEntry } from '../lib/content';

interface Props {
  note: NoteEntry;
  locale: Locale;
}

const { note, locale } = Astro.props;
const normalize = (value: string) => value.trim().toLowerCase();
const tagTokens = note.data.tags.map(normalize).join('|');
---

<article
  class="surface-card rounded-lg p-6 transition hover:border-site-border-strong"
  data-filter-item
  data-category={normalize(note.data.category)}
  data-tags={tagTokens}
>
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div class="max-w-3xl">
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-site-accent">{note.data.category}</p>
      <h3 class="mt-3 text-2xl font-semibold tracking-[-0.035em] text-site">
        <a href={localizedPath(locale, `/notes/${note.data.slug}/`)} class="focus-ring rounded-md">{note.data.title}</a>
      </h3>
      <p class="mt-3 text-sm leading-7 text-site-muted">{note.data.description}</p>
    </div>
    <div class="text-right text-xs text-site-subtle">
      <p>{formatDate(note.data.publishedAt, locale)}</p>
      <p class="mt-2">{readingTime(note.body, locale)}</p>
    </div>
  </div>

  {note.data.tags.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-2">
      {note.data.tags.map((tag) => <TagPill label={tag} />)}
    </div>
  )}
</article>
