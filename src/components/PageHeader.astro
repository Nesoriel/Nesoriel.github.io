---
interface Props { eyebrow?: string; title: string; description: string; }
const { eyebrow, title, description } = Astro.props;
---
<section class="mx-auto w-full max-w-7xl px-5 pb-10 pt-20 sm:px-6 lg:px-8">
  {eyebrow && <p class="mb-4 text-sm font-medium uppercase tracking-[0.22em] text-site-accent">{eyebrow}</p>}
  <h1 class="max-w-4xl text-4xl font-semibold tracking-[-0.045em] sm:text-5xl lg:text-6xl">{title}</h1>
  <p class="mt-5 max-w-2xl text-base leading-8 text-site-muted sm:text-lg">{description}</p>
</section>
