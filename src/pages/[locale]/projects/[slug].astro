---
import { supportedLocales } from '../../../config/site';
import { getPublicProjects } from '../../../lib/content';
import ProjectPage from '../../../views/ProjectPage.astro';

export async function getStaticPaths() {
  const paths = await Promise.all(
    supportedLocales.map(async (locale) => {
      const projects = await getPublicProjects(locale);
      return projects.map((project) => ({ params: { locale, slug: project.data.slug }, props: { locale, project } }));
    }),
  );

  return paths.flat();
}

const { locale, project } = Astro.props as Awaited<ReturnType<typeof getStaticPaths>>[number]['props'];
---

<ProjectPage locale={locale} project={project} />
