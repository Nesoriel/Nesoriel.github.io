---
import { siteConfig } from '../../config/site';
import { getPulseEntries } from '../../lib/pulse';
import PulseDetailPage from '../../views/PulseDetailPage.astro';

export function getStaticPaths() {
  const entries = getPulseEntries();
  return entries.map((entry, index) => ({
    params: { date: entry.date },
    props: { entry, previous: entries[index + 1], next: entries[index - 1] },
  }));
}

const { entry, previous, next } = Astro.props as Awaited<ReturnType<typeof getStaticPaths>>[number]['props'];
---

<PulseDetailPage locale={siteConfig.defaultLocale} entry={entry} previous={previous} next={next} />
